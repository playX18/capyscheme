(define with-syntax
  (let ((make-syntax make-syntax))
    (make-syntax-transformer
      'with-syntax
      'macro
      (cons (lambda (x)
              (let ((tmp x))
                (let ((tmp-1 ($sc-dispatch tmp '(_ () any . each-any))))
                  (if tmp-1
                      (apply (lambda (e1 e2)
                               (cons (make-syntax
                                       'let
                                       '((top))
                                       '(hygiene capy))
                                     (cons '() (cons e1 e2))))
                             tmp-1)
                      (let ((tmp-1.1
                              ($sc-dispatch
                                tmp
                                '(_ ((any any)) any . each-any))))
                        (if tmp-1.1
                            (apply (lambda (out in e1 e2)
                                     (list (make-syntax
                                             'syntax-case
                                             '((top))
                                             '(hygiene capy))
                                           in
                                           '()
                                           (list out
                                                 (cons (make-syntax
                                                         'let
                                                         '((top))
                                                         '(hygiene capy))
                                                       (cons '()
                                                             (cons e1 e2))))))
                                   tmp-1.1)
                            (let ((tmp-1.2
                                    ($sc-dispatch
                                      tmp
                                      '(_ #(each (any any)) any . each-any))))
                              (if tmp-1.2
                                  (apply (lambda (out in e1 e2)
                                           (list (make-syntax
                                                   'syntax-case
                                                   '((top))
                                                   '(hygiene capy))
                                                 (cons (make-syntax
                                                         'list
                                                         '((top))
                                                         '(hygiene capy))
                                                       in)
                                                 '()
                                                 (list out
                                                       (cons (make-syntax
                                                               'let
                                                               '((top))
                                                               '(hygiene capy))
                                                             (cons '()
                                                                   (cons e1
                                                                         e2))))))
                                         tmp-1.2)
                                  (syntax-violation
                                    '#f
                                    '"source expression failed to match any pattern"
                                    tmp)))))))))
            (make-syntax '#f '((top)) '(hygiene capy))))))
(define syntax-error
  (let ((make-syntax make-syntax))
    (letrec*
      ((string-join
         (lambda (args)
           (letrec*
             ((result (open-output-string))
              (len (length args)))
             (letrec ((loop (lambda (i args.1)
                              (if (null? args.1)
                                  (get-output-string result)
                                  (begin
                                    (cond ((> i '0) (write-string '" " result))
                                          (#f #f))
                                    (begin
                                      (write-string (car args.1) result)
                                      (loop (+ i '1) (cdr args.1))))))))
               (loop '0 args))))))
      (make-syntax-transformer
        'syntax-error
        'macro
        (cons (lambda (x)
                (let ((tmp-1 x))
                  (let ((tmp ($sc-dispatch
                               tmp-1
                               '(_ (any . any) any . each-any))))
                    (if (if tmp
                            (apply (lambda (keyword operands message arg)
                                     (string? (syntax->datum message)))
                                   tmp)
                            '#f)
                        (apply (lambda (keyword operands message arg)
                                 (syntax-violation
                                   (syntax->datum keyword)
                                   (string-join
                                     (cons (syntax->datum message)
                                           (map (lambda (x.1)
                                                  (format
                                                    '"~a"
                                                    (syntax->datum x.1)))
                                                arg)))
                                   (if (syntax->datum keyword)
                                       (cons keyword operands)
                                       '#f)))
                               tmp)
                        (let ((tmp.1 ($sc-dispatch tmp-1 '(_ any . each-any))))
                          (if (if tmp.1
                                  (apply (lambda (message arg)
                                           (string? (syntax->datum message)))
                                         tmp.1)
                                  '#f)
                              (apply (lambda (message arg)
                                       (cons (make-syntax
                                               'syntax-error
                                               (list '(top)
                                                     (vector
                                                       'ribcage
                                                       '#(syntax-error)
                                                       '#((top))
                                                       (vector
                                                         (cons '(hygiene capy)
                                                               (make-syntax
                                                                 'syntax-error
                                                                 '((top))
                                                                 '(hygiene
                                                                    capy))))))
                                               '(hygiene capy))
                                             (cons '(#f) (cons message arg))))
                                     tmp.1)
                              (syntax-violation
                                '#f
                                '"source expression failed to match any pattern"
                                tmp-1)))))))
              (make-syntax '#f '((top)) '(hygiene capy)))))))

(define let*
  (let ((make-syntax make-syntax))
    (make-syntax-transformer
      'let*
      'macro
      (cons (lambda (x)
              (let ((tmp-1 x))
                (let ((tmp ($sc-dispatch
                             tmp-1
                             '(any #(each (any any)) any . each-any))))
                  (if (if tmp
                          (apply (lambda (let* x.1 v e1 e2)
                                   (and-map identifier? x.1))
                                 tmp)
                          '#f)
                      (apply (lambda (let* x.1 v e1 e2)
                               (letrec ((f (lambda (bindings)
                                             (if (null? bindings)
                                                 (cons (make-syntax
                                                         'let
                                                         '((top))
                                                         '(hygiene capy))
                                                       (cons '() (cons e1 e2)))
                                                 (let ((tmp-1.1
                                                         (list (f (cdr bindings))
                                                               (car bindings))))
                                                   (let ((tmp.1 ($sc-dispatch
                                                                  tmp-1.1
                                                                  '(any any))))
                                                     (if tmp.1
                                                         (apply (lambda (body
                                                                         binding)
                                                                  (list (make-syntax
                                                                          'let
                                                                          '((top))
                                                                          '(hygiene
                                                                             capy))
                                                                        (list binding)
                                                                        body))
                                                                tmp.1)
                                                         (syntax-violation
                                                           '#f
                                                           '"source expression failed to match any pattern"
                                                           tmp-1.1))))))))
                                 (f (map list x.1 v))))
                             tmp)
                      (syntax-violation
                        '#f
                        '"source expression failed to match any pattern"
                        tmp-1)))))
            (make-syntax '#f '((top)) '(hygiene capy))))))
